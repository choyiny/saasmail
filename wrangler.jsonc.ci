{
  // CI-only wrangler config. Used by .github/workflows/test.yml to satisfy
  // vitest-pool-workers, which requires a wrangler.jsonc to be present.
  // Values here are placeholders sufficient for unit tests — not for deploy.
  "name": "saasmail",
  "main": "worker/src/index.ts",
  "compatibility_date": "2026-04-14",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "saasmail-db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "saasmail-attachments"
    }
  ],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "email_routing": {
    "enabled": true
  },
  "observability": {
    "enabled": true
  },
  "queues": {
    "producers": [
      {
        "binding": "EMAIL_QUEUE",
        "queue": "saasmail-sequence-emails"
      }
    ],
    "consumers": [
      {
        "queue": "saasmail-sequence-emails",
        "max_batch_size": 10,
        "max_retries": 3
      }
    ]
  },
  "triggers": {
    "crons": ["0 * * * *"]
  },
  "vars": {
    "BASE_URL": "http://localhost:8080",
    "TRUSTED_ORIGINS": "http://localhost:8080,http://localhost:8788",
    "COOKIE_PREFIX": "saasmail",
    "DISABLE_PASSKEY_GATE": "true"
  }
}
