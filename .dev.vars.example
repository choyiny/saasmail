# Outbound provider precedence: Bavimail (BAVIMAIL_API_KEY + BAVIMAIL_ALIAS_ID)
# > Postmark (POSTMARK_API_KEY) > Resend (RESEND_API_KEY) > Cloudflare Email
# Sending (EMAIL binding). Set only the one you use.
BAVIMAIL_API_KEY=
BAVIMAIL_ALIAS_ID=

# Postmark server API token.
POSTMARK_API_KEY=

RESEND_API_KEY=re_xxxx
BETTER_AUTH_SECRET=generate-a-random-secret

# Local-only: relaxes passkey enforcement so you can log in with
# email+password and hit the API without registering a WebAuthn
# credential. Set to "true" for local dev; omit / leave blank in prod.
DISABLE_PASSKEY_GATE=true

# Local-only: short-circuits real email sending (compose returns a
# synthetic demo_... id). Required by `yarn test:e2e`; safe to leave
# off for normal `yarn dev`. Never set in production.
DEMO_MODE=1

# Secret used to sign one-click unsubscribe tokens (HMAC). Generate
# with: openssl rand -hex 32. Set in prod via:
#   wrangler secret put UNSUBSCRIBE_SECRET
UNSUBSCRIBE_SECRET=replace-with-output-of-openssl-rand-hex-32
