# config/template.env — schema for forking saasmail to a new operator.
#
# Copy this to config/<env>.env (e.g. config/production.env) and fill in:
#
#   1. Identity values (WORKER_NAME, EMAIL_DOMAIN, BASE_URL).
#   2. Run `mise run cf:provision-d1-r2`   — creates D1 + R2, writes IDs back.
#   3. Run `mise run cf:provision-queues`  — creates the EMAIL_QUEUE.
#   4. Run `mise run cf:access-setup`      — creates Access App + writes fnox values.
#   5. Run `mise run cf:secrets-put-mapped` — pushes Worker secrets from fnox.
#   6. Run `mise run vapid:generate`       — generates + sets VAPID keys for Web Push.
#   7. Run `mise run 10-deploy`.
#   8. Configure CF Email Routing in dashboard (catch-all → this Worker).
#
# Every mise task accepts `-- --env <env>` to switch which config file
# it reads. Default is `production`.
#
# DO NOT COMMIT config/<env>.env — they're gitignored.

# ── Identity ─────────────────────────────────────────────────────────────────

WORKER_NAME=saasmail
CF_SUBDOMAIN=gedw99

# Domain that will receive inbound mail (must be on Cloudflare with Email
# Routing enabled — see manual setup steps in the dashboard).
EMAIL_DOMAIN=example.com

# Public URL the SPA sees as its origin. For *.workers.dev:
#   https://${WORKER_NAME}.${CF_SUBDOMAIN}.workers.dev
BASE_URL=https://saasmail.gedw99.workers.dev
TRUSTED_ORIGINS=http://localhost:8080,http://localhost:8788,https://saasmail.gedw99.workers.dev
COOKIE_PREFIX=saasmail

# ── Cloudflare resources (set/updated by `mise run cf:provision-*`) ──────────

# Saasmail's metadata D1 (people, emails, attachments meta, sent emails, etc.)
METADATA_DB_NAME=saasmail-db
METADATA_DB_ID=

# R2 bucket for attachment storage.
BACKUP_BUCKET_NAME=saasmail-attachments

# CF Queue for sequence email scheduling (cron pulls from here).
QUEUE_NAMES=saasmail-sequence-emails
EMAIL_QUEUE_NAME=saasmail-sequence-emails

# ── Web Push VAPID (generated by `mise run vapid:generate`) ──────────────────
# VAPID_PRIVATE_KEY is set as a Worker secret (NOT here, NOT committed).
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:gedw99@gmail.com

# ── Cloudflare Account / Access ──────────────────────────────────────────────
# CLOUDFLARE_ACCOUNT_ID comes from fnox; envsubst pulls it via env.
# Set globally one-time: fnox set --provider keychain CLOUDFLARE_ACCOUNT_ID
CLOUDFLARE_ACCOUNT_ID=

OPERATOR_EMAIL=gedw99@gmail.com

# Subset of fnox keys to also sync to GitHub Actions secrets (CI deploys).
FNOX_SYNC_KEYS=

# Per-Worker fnox keys for cf:access-setup and cf:secrets-put-mapped.
APP_POLICY_AUD_FNOX_KEY=SAASMAIL_POLICY_AUD
